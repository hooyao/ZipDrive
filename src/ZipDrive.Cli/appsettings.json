{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "Mount": {
    "MountPoint": "R:\\",
    "ArchiveDirectory": "",
    "MaxDiscoveryDepth": 6,
    "ShortCircuitShellMetadata": true
  },
  "Cache": {
    "MemoryCacheSizeMb": 2048,
    "DiskCacheSizeMb": 10240,
    "SmallFileCutoffMb": 50,
    "TempDirectory": null,
    "DefaultTtlMinutes": 30,
    "EvictionCheckIntervalSeconds": 10
  },
  "OpenTelemetry": {
    "Endpoint": ""
  }
}
